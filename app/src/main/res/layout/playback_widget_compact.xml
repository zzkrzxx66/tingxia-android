<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <ImageView
        android:id="@+id/widget_artwork"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/widget_artwork_background"
        android:contentDescription="@string/widget_artwork"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_widget_artwork_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_book_title"
            android:layout_width="match_parent"
            android:layout_height="19dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="@color/widget_on_surface"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_chapter_title"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/widget_no_media"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="3dp"
            android:indeterminate="false"
            android:progressBackgroundTint="@color/widget_progress_track"
            android:progressTint="@color/widget_accent" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:visibility="gone"
            android:text="@string/widget_tap_to_resume" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginStart="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_previous"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/widget_control_background"
            android:contentDescription="@string/previous_chapter"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_previous"
            android:tint="@color/widget_on_control" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_primary_control_background"
            android:contentDescription="@string/play"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_play"
            android:tint="@color/widget_on_primary_control" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_control_background"
            android:contentDescription="@string/next_chapter"
            android:padding="6dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_widget_next"
            android:tint="@color/widget_on_control" />
    </LinearLayout>
</LinearLayout>
