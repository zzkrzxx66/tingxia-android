<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/widget_artwork"
        android:layout_width="112dp"
        android:layout_height="112dp"
        android:background="@drawable/widget_artwork_background"
        android:contentDescription="@string/widget_artwork"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_widget_artwork_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_book_title"
            android:layout_width="match_parent"
            android:layout_height="25dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="@color/widget_on_surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_chapter_title"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/widget_no_media"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:indeterminate="false"
            android:progressBackgroundTint="@color/widget_progress_track"
            android:progressTint="@color/widget_accent" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:layout_marginTop="7dp"
            android:ellipsize="end"
            android:fontFamily="sans"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:text="@string/widget_tap_to_resume"
            android:textColor="@color/widget_on_surface_variant"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/widget_previous"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/widget_control_background"
                android:contentDescription="@string/previous_chapter"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_widget_previous"
                android:tint="@color/widget_on_control" />

            <ImageButton
                android:id="@+id/widget_play_pause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/widget_primary_control_background"
                android:contentDescription="@string/play"
                android:padding="9dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_widget_play"
                android:tint="@color/widget_on_primary_control" />

            <ImageButton
                android:id="@+id/widget_next"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/widget_control_background"
                android:contentDescription="@string/next_chapter"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_widget_next"
                android:tint="@color/widget_on_control" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
